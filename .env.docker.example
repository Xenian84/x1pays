# Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# Network Configuration
NETWORK=x1-testnet

# Token Configuration
WXNT_MINT=So11111111111111111111111111111111111111112

# Facilitator Secrets (NEVER commit actual secrets!)
# Generate using: solana-keygen new
FACILITATOR_ALPHA_SECRET=your_alpha_secret_key_here
FACILITATOR_BETA_SECRET=your_beta_secret_key_here
FEE_PAYER_SECRET=your_production_facilitator_secret_here

# Production URLs (for docker-compose.prod.yml)
FACILITATOR_URL=https://facilitator.yourdomain.com
API_URL=https://api.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Facilitator Configuration
FACILITATOR_ID=prod
FACILITATOR_NAME=Production Facilitator
FEE_BASIS_POINTS=10
