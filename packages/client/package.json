{
  "name": "@x1pay/client",
  "version": "0.2.0",
  "type": "module",
  "description": "x402 payment client libraries for Axios and Fetch API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "import": "./dist/axios.js",
      "require": "./dist/axios.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js",
      "require": "./dist/fetch.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "x402",
    "payments",
    "client",
    "x1",
    "blockchain",
    "axios",
    "fetch"
  ],
  "author": "X1Pays <team@x1pays.xyz>",
  "license": "MIT",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/Xenian84/x1pays.git",
    "directory": "packages/client"
  },
  "homepage": "https://x1pays.xyz",
  "bugs": {
    "url": "https://github.com/Xenian84/x1pays/issues"
  },
  "peerDependencies": {
    "axios": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "bs58": "^5.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "axios": "^1.7.9",
    "typescript": "^5.7.2"
  }
}
