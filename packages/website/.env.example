# Website Configuration

# X1 Blockchain Network
# Options: x1-mainnet, x1-testnet
VITE_NETWORK=x1-testnet

# X1 RPC URLs
VITE_X1_TESTNET_RPC=https://rpc-testnet.x1.xyz
VITE_X1_MAINNET_RPC=https://rpc.x1.xyz

# Facilitator Service URL
# Development: http://localhost:4000
# Production: Your deployed facilitator URL
VITE_FACILITATOR_URL=http://localhost:4000

# Echo Demo Configuration
# Merchant wallet address (receives payments)
VITE_MERCHANT_ADDRESS=

# wXNT Token Mint Address
# Get the correct mint address for your network from X1 documentation
VITE_WXNT_MINT=

# USDX Token Mint Address (mainnet only)
VITE_USDX_MINT=
