# API Service Configuration

# Server port
PORT=3000

# X1 Blockchain Network
# Options: x1-mainnet, x1-testnet
NETWORK=x1-testnet

# X1 RPC URL
# Mainnet: https://rpc.x1.xyz
# Testnet: https://rpc-testnet.x1.xyz
RPC_URL=https://rpc-testnet.x1.xyz

# wXNT Token Mint Address
# Get the correct mint address for your network from X1 documentation
WXNT_MINT=

# Merchant Wallet Address (receives payments)
# This is YOUR wallet address where payments will be sent
PAYTO_ADDRESS=

# Facilitator Service URL
# Development: http://localhost:4000
# Production: Your deployed facilitator URL
FACILITATOR_URL=http://localhost:4000

# Public Domain
# The public domain where this API is hosted
DOMAIN=localhost
