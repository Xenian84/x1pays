# API Service Configuration

# Server port
PORT=3000

# X1 Network RPC URL
RPC_URL=https://rpc.mainnet.x1.xyz

# Network identifier
NETWORK=x1-mainnet

# wXNT SPL token mint address
WXNT_MINT=ReplaceWith_wXNT_Mint_Address

# Merchant wallet address that receives payments
PAYTO_ADDRESS=ReplaceWithMerchantPubkey

# Facilitator service URL
FACILITATOR_URL=http://localhost:4000

# Public domain for this service
DOMAIN=x1pays.xyz

# Protocol fee percentage (1 = 1%)
FEE_PERCENT=1

# X1Pays treasury address for fee collection
TREASURY_ADDRESS=ReplaceWithTreasuryPubkey

# XPY governance token mint address
XPY_MINT=ReplaceWith_XPY_Token_Mint
