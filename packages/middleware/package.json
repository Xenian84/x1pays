{
  "name": "@x1pay/middleware",
  "version": "0.3.0",
  "type": "module",
  "description": "x402 payment middleware for Express, Hono, Fastify, and Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "x402",
    "payments",
    "middleware",
    "x1",
    "blockchain"
  ],
  "author": "X1Pays <team@x1pays.xyz>",
  "license": "MIT",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/Xenian84/x1pays.git",
    "directory": "packages/middleware"
  },
  "homepage": "https://x1pays.xyz",
  "bugs": {
    "url": "https://github.com/Xenian84/x1pays/issues"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.0.0",
    "hono": "^4.0.0",
    "next": "^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "fastify-plugin": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "express": "^4.21.2",
    "fastify": "^5.2.0",
    "hono": "^4.6.17",
    "next": "^16.0.0",
    "typescript": "^5.7.2"
  }
}
