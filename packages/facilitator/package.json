{
  "name": "@x1pay/facilitator",
  "version": "0.1.0",
  "description": "x402 payment facilitator service for X1 blockchain - handles signature verification and blockchain settlement",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "x402",
    "facilitator",
    "payments",
    "x1",
    "blockchain",
    "settlement"
  ],
  "author": "X1Pays",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xenian84/x1pays.git",
    "directory": "packages/facilitator"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:alpha": "dotenv -e .env.alpha -- tsx src/index.ts",
    "dev:beta": "dotenv -e .env.beta -- tsx src/index.ts",
    "dev:gamma": "dotenv -e .env.gamma -- tsx src/index.ts",
    "dev:alpha-mainnet": "dotenv -e .env.alpha-mainnet -- tsx src/index.ts",
    "dev:beta-mainnet": "dotenv -e .env.beta-mainnet -- tsx src/index.ts",
    "dev:gamma-mainnet": "dotenv -e .env.gamma-mainnet -- tsx src/index.ts",
    "generate": "tsx scripts/generate-facilitators.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@solana/spl-token": "^0.3.9",
    "@solana/web3.js": "^1.87.6",
    "@x1pay/client": "workspace:*",
    "@x1pay/shared": "workspace:*",
    "body-parser": "^1.20.2",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "tweetnacl": "^1.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "dotenv-cli": "^7.4.4",
    "tsx": "^4.7.0",
    "vitest": "^1.0.4"
  }
}
