# Facilitator Service Configuration

# Server port
PORT=4000

# X1 Network RPC URL
RPC_URL=https://rpc.mainnet.x1.xyz

# Network identifier (x1-mainnet or x1-devnet)
NETWORK=x1-mainnet

# wXNT SPL token mint address on X1
WXNT_MINT=ReplaceWith_wXNT_Mint_Address

# Fee payer wallet secret key (base58 encoded)
# This wallet pays transaction fees on X1
FEE_PAYER_SECRET=ReplaceWithBase58SecretKey

# Merchant wallet address that receives 99% of payments
MERCHANT_WALLET=ReplaceWithMerchantPubkey

# Protocol fee percentage (1 = 1%)
FEE_PERCENT=1

# X1Pays treasury address for fee collection
TREASURY_ADDRESS=ReplaceWithTreasuryPubkey

# XPY governance token mint address (not used for settlement)
XPY_MINT=ReplaceWith_XPY_Token_Mint
