# Facilitator Service Configuration

# Server port
PORT=4000

# X1 Blockchain Network
# Options: x1-mainnet, x1-testnet
NETWORK=x1-testnet

# X1 RPC URL
# Mainnet: https://rpc.x1.xyz
# Testnet: https://rpc-testnet.x1.xyz
RPC_URL=https://rpc-testnet.x1.xyz

# wXNT Token Mint Address
# Get the correct mint address for your network from X1 documentation
WXNT_MINT=
USDX_MINT=

# Fee Payer Secret Key (Base58 encoded)
# WARNING: NEVER commit the actual secret key to version control!
# This wallet pays gas fees for all settlements (X1Pays covers user gas costs)
# Generate using: solana-keygen new --outfile fee-payer.json
# Export base58: solana-keygen pubkey fee-payer.json --outfile /dev/stdout
FEE_PAYER_SECRET=
